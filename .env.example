# Flask
SECRET_KEY=replace-with-a-long-random-secret
FLASK_ENV=development
FLASK_DEBUG=0
PORT=4000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
TRUST_PROXY=0
PUBLIC_BASE_URL=http://localhost:4000

# Uploads
MAX_UPLOAD_BYTES=10485760

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MAX_OUTPUT_TOKENS=8192
MAX_GEMINI_HISTORY_MESSAGES=40

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=webdevai
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=20000
DEBUG_MONGO=0

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback
